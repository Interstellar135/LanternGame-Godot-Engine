[sub_resource type="GDScript" id="GDScript_wrhoe"]
script/source = "# HUD.gd - 挂载到 CanvasLayer 节点（HUD）
extends CanvasLayer  # 【关键】必须是 CanvasLayer！

@onready var health_bar = $HealthBarBg/HealthBar as ProgressBar
@onready var health_label = $HealthBarBg/HealthLabel as Label
var player = null

func _ready():
	# 尝试获取Player（通过组\"player\"）
	_find_player()
	
	# 安全兜底：每0.2秒检查Player（应对动态生成）
	var check_timer = Timer.new()
	check_timer.wait_time = 0.2
	check_timer.one_shot = false
	check_timer.timeout.connect(_find_player)
	add_child(check_timer)  # CanvasLayer 继承 Node2D，支持 add_child
	check_timer.start()

func _find_player():
	if player: return
	var players = get_tree().get_nodes_in_group(\"player\")
	if players.size() > 0:
		player = players[0]
		_connect_signals()
		print(\"✅ HUD已连接Player！血条激活\")

func _connect_signals():
	if not player or not player.is_inside_tree() or not player.has_signal(\"health_changed\"):
		return
	player.health_changed.connect(_on_player_health_changed)
	_on_player_health_changed(player.health, player.max_health)  # 初始化显示

func _on_player_health_changed(current: int, max: int):
	if health_bar:
		health_bar.value = float(current) / max
	if health_label:
		health_label.text = \"%d/%d\" % [current, max]
		# 血量低时变红（可选）
		if current <= max * 0.3:
			health_label.add_theme_color_override(\"font_color\", Color.RED)
		else:
			health_label.add_theme_color_override(\"font_color\", Color.WHITE)
"

